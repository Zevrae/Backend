PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/zevrae
NODE_ENV=development
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Public base URL of this API, used to build the email verification link
# (e.g. https://api.yourdomain.com). Defaults to http://localhost:<PORT>.
API_BASE_URL=http://localhost:5000

# How long an email verification token stays valid, in hours
EMAIL_VERIFICATION_EXPIRES_HOURS=24

# --- SMTP (for sending verification emails) ---
# If SMTP_HOST is left blank, emails are logged to the console instead of
# actually being sent — useful for local development without a mail server.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Zevrae <no-reply@zevrae.com>"

# --- Payments (Razorpay) ---
# Get these from the Razorpay Dashboard > Settings > API Keys.
# Leave blank to run the app without payments enabled (orders are still
# created, just without a Razorpay checkout attached).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_CURRENCY=INR
# From Dashboard > Settings > Webhooks, after you register /api/payments/webhook
RAZORPAY_WEBHOOK_SECRET=

# --- Product image storage (Appwrite Storage) ---
# Leave any of these blank to disable image uploads (existing image URLs still work).
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_BUCKET_ID=

